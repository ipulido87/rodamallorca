# Core Configuration
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rodamallorca

# Authentication - JWT Secret (mínimo 32 caracteres)
# Genera uno nuevo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# Google OAuth (Opcional - descomenta si usas OAuth)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# GOOGLE_LOGIN_REDIRECT_URI=http://localhost:5173/auth/callback

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PRICE_ID=price_your_stripe_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Cloudinary (Opcional - para almacenamiento de imágenes)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Email con Resend
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Roda Mallorca <noreply@rodamallorca.com>

# Push Notifications (Opcional)
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:your-email@example.com

# Gemini AI - Búsqueda inteligente (Opcional - funciona sin ella con fallback local)
# Obtener gratis en: https://aistudio.google.com/apikey
# Tier gratuito: 15 RPM, 1M tokens/día
# GEMINI_API_KEY=your-gemini-api-key-here
