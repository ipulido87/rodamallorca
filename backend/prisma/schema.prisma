generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String?
  googleId         String?  @unique
  name             String?
  picture          String?
  birthDate        DateTime?
  phone            String?  // puedes añadir @unique si quieres
  verificationCode String?
  verified         Boolean  @default(false)
  codeExpiresAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}



model Workshop {
  id          String   @id @default(uuid())
  ownerId     String   // User.id del dueño del taller
  name        String
  description String?
  address     String?
  city        String?
  country     String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Product {
  id          String        @id @default(uuid())
  workshopId  String
  categoryId  String?
  title       String
  description String?
  price       Int            // en céntimos (recomendado)
  currency    String  @default("EUR")
  condition   String  @default("used") // 'new' | 'used' | 'refurb'
  status      String  @default("DRAFT") // 'DRAFT' | 'PUBLISHED' | 'SOLD'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workshop    Workshop   @relation(fields: [workshopId], references: [id])
  category    Category?  @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  position  Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id])
}
