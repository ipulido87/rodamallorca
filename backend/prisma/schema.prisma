generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}
enum UserRole {
  USER
  WORKSHOP_OWNER
  ADMIN
}

enum OrderStatus {
  PENDING      // Pedido creado, esperando confirmación
  CONFIRMED    // Confirmado por el taller
  IN_PROGRESS  // En proceso de preparación
  READY        // Listo para recoger/entregar
  COMPLETED    // Completado
  CANCELLED    // Cancelado
}

enum OrderType {
  PRODUCT_ORDER    // Compra de productos
  SERVICE_REPAIR   // Reparación/servicio
}

enum VehicleType {
  BICYCLE      // Bicicleta convencional
  E_BIKE       // Bicicleta eléctrica
  E_SCOOTER    // Patinete eléctrico
  ALL          // Aplica a todos los tipos
}

enum ServiceStatus {
  ACTIVE       // Servicio activo y disponible
  INACTIVE     // Servicio desactivado temporalmente
}

enum InvoiceStatus {
  DRAFT        // Borrador (sin enviar)
  SENT         // Enviada al cliente
  PAID         // Pagada
  OVERDUE      // Vencida (no pagada)
  CANCELLED    // Cancelada
}

enum CustomerType {
  INDIVIDUAL   // Particular
  BUSINESS     // Empresa
}

enum SubscriptionStatus {
  TRIALING     // En período de prueba
  ACTIVE       // Activa y pagando
  PAST_DUE     // Pago vencido
  CANCELED     // Cancelada
  INCOMPLETE   // Pago inicial incompleto
  UNPAID       // Sin pagar
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String?
  googleId         String?  @unique
  name             String?
  picture          String?
  birthDate        DateTime?
  phone            String?
  verificationCode String?
  verified         Boolean  @default(false)
  codeExpiresAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  role             UserRole @default(USER)
  resetToken         String?
  resetTokenExpiresAt DateTime?

  // Relaciones
  workshops         Workshop[]
  orders            Order[]       // Pedidos realizados por el usuario
  vehicles          Vehicle[]     // Vehículos del usuario
  favoriteWorkshops FavoriteWorkshop[] // Talleres favoritos
  settings          UserSettings? // Configuración del usuario
}

// Configuración de usuario
model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  settings  Json     // Configuración en formato JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Vehículos de los usuarios (bicicletas, patinetes)
model Vehicle {
  id          String      @id @default(uuid())
  userId      String      // Propietario del vehículo
  type        VehicleType @default(BICYCLE)
  brand       String?     // Marca (ej: "Trek", "Giant", "Xiaomi")
  model       String?     // Modelo
  year        Int?        // Año de fabricación
  color       String?     // Color
  serialNumber String?    // Número de serie
  notes       String?     // Notas adicionales
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relaciones
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[] // Reparaciones asociadas a este vehículo

  @@index([userId])
}

model Workshop {
  id          String   @id @default(uuid())
  ownerId     String   
  name        String
  description String?
  address     String?
  city        String?
  country     String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  owner          User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products       Product[]
  services       Service[]         // Servicios ofrecidos por el taller
  orders         Order[]           // Pedidos recibidos por este taller
  invoices       Invoice[]         // Facturas emitidas por este taller
  customers      Customer[]        // Clientes del taller
  invoiceSeries  InvoiceSeries[]   // Series de facturación del taller
  favoritedBy    FavoriteWorkshop[] // Usuarios que tienen este taller como favorito
  subscription   Subscription?     // Suscripción del taller

  @@index([ownerId])
  @@index([city])
  @@index([country])
  @@index([createdAt])
}

// Suscripciones de talleres (Stripe)
model Subscription {
  id                    String             @id @default(uuid())
  workshopId            String             @unique

  // IDs de Stripe
  stripeCustomerId      String             @unique
  stripeSubscriptionId  String?            @unique
  stripePriceId         String             // ID del precio en Stripe (price_xxx)

  // Estado de la suscripción
  status                SubscriptionStatus @default(TRIALING)

  // Períodos
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  trialStart            DateTime?
  trialEnd              DateTime?
  canceledAt            DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)

  // Billing
  defaultPaymentMethodId String?           // ID del método de pago en Stripe

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  // Relaciones
  workshop              Workshop           @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

// Talleres favoritos de los usuarios
model FavoriteWorkshop {
  id         String   @id @default(uuid())
  userId     String   // Usuario que marcó como favorito
  workshopId String   // Taller favorito
  createdAt  DateTime @default(now())

  // Relaciones
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([userId, workshopId]) // Un usuario no puede marcar el mismo taller dos veces
  @@index([userId])
  @@index([workshopId])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
}

model Product {
  id          String    @id @default(uuid())
  workshopId  String
  categoryId  String?
  title       String
  description String?
  price       Int       // en céntimos
  currency    String    @default("EUR")
  condition   String    @default("used")   
  status      String    @default("DRAFT")  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  orderItems  OrderItem[] // Items de pedidos que referencian este producto

  @@index([workshopId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  original  String
  medium    String
  thumbnail String
  position  Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, position])
}

model Order {
  id                  String      @id @default(uuid())
  userId              String      // Cliente que realiza el pedido
  workshopId          String      // Taller que recibe el pedido
  type                OrderType   @default(PRODUCT_ORDER) // Tipo de orden
  status              OrderStatus @default(PENDING)
  totalAmount         Int         // Total en céntimos
  currency            String      @default("EUR")
  notes               String?     // Notas del cliente

  // Campos específicos para reparaciones
  vehicleId           String?     // Vehículo del cliente (opcional)
  estimatedDelivery   DateTime?   // Fecha estimada de entrega (opcional)
  diagnosis           String?     // Diagnóstico del taller (opcional)
  laborHours          Decimal?    @db.Decimal(5, 2) // Horas de mano de obra (opcional)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relaciones
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop    Workshop    @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  invoice     Invoice?    // Factura generada automáticamente (si existe)

  @@index([userId])
  @@index([workshopId])
  @@index([vehicleId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  productId    String?  // Puede ser null si es un servicio
  serviceId    String?  // Puede ser null si es un producto
  quantity     Int      @default(1)
  priceAtOrder Int      // Precio en céntimos al momento del pedido
  currency     String   @default("EUR")
  description  String?  // Descripción del item (para servicios personalizados)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([serviceId])
}

// Categorías de servicios (Ruedas, Transmisión, Frenos, etc.)
model ServiceCategory {
  id          String    @id @default(uuid())
  name        String    @unique // "Ruedas y neumáticos", "Transmisión", etc.
  description String?
  icon        String?   // Nombre del icono para la UI
  position    Int       @default(0) // Para ordenar las categorías
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  services    Service[]

  @@index([position])
}

// Servicios ofrecidos por cada taller
model Service {
  id                String        @id @default(uuid())
  workshopId        String
  serviceCategoryId String
  name              String        // "Cambio de cubiertas y cámaras"
  description       String?       // Descripción detallada del servicio
  price             Int           // Precio en céntimos
  currency          String        @default("EUR")
  duration          Int?          // Duración estimada en minutos
  vehicleType       VehicleType   @default(ALL) // Tipo de vehículo
  status            ServiceStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relaciones
  workshop        Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  orderItems      OrderItem[]     // Items de pedidos que referencian este servicio

  @@index([workshopId])
  @@index([serviceCategoryId])
  @@index([status])
  @@index([vehicleType])
  @@index([createdAt])
}// Clientes para facturación
model Customer {
  id           String       @id @default(uuid())
  workshopId   String
  type         CustomerType @default(INDIVIDUAL)
  name         String       // Nombre o razón social
  taxId        String?      // NIF/CIF/VAT
  email        String?
  phone        String?
  address      String?
  city         String?
  postalCode   String?
  country      String?      @default("España")
  notes        String?      // Notas internas
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relaciones
  workshop     Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([workshopId])
  @@index([taxId])
  @@index([email])
}

// Series de facturación (para numeración automática)
model InvoiceSeries {
  id          String    @id @default(uuid())
  workshopId  String
  name        String    // ej: "2025", "Facturas Generales"
  prefix      String    // ej: "F", "INV"
  nextNumber  Int       @default(1)
  year        Int       // Año de la serie
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  workshop    Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@unique([workshopId, prefix, year])
  @@index([workshopId])
}

// Facturas
model Invoice {
  id              String        @id @default(uuid())
  workshopId      String
  customerId      String?       // Puede ser null para facturas sin cliente específico
  seriesId        String
  orderId         String?       @unique // Pedido del que se generó (si aplica)
  invoiceNumber   String        // ej: "F-2025-001"
  issueDate       DateTime      @default(now())
  dueDate         DateTime?     // Fecha de vencimiento
  status          InvoiceStatus @default(DRAFT)

  // Totales
  subtotal        Int           // Subtotal en céntimos (antes de impuestos)
  taxAmount       Int           // Total de impuestos en céntimos
  total           Int           // Total en céntimos
  currency        String        @default("EUR")

  // Datos adicionales
  notes           String?       // Notas visibles en la factura
  internalNotes   String?       // Notas internas (no visibles en PDF)
  pdfUrl          String?       // URL del PDF generado
  paymentMethod   String?       // Efectivo, Tarjeta, Transferencia, etc.
  paidAt          DateTime?     // Fecha de pago

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relaciones
  workshop        Workshop      @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  series          InvoiceSeries @relation(fields: [seriesId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items           InvoiceItem[]

  @@unique([workshopId, invoiceNumber])
  @@index([workshopId])
  @@index([customerId])
  @@index([seriesId])
  @@index([orderId])
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
}

// Líneas de factura
model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String   // Descripción del concepto
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Int      // Precio unitario en céntimos
  discount    Int      @default(0) // Descuento en céntimos
  taxRate     Decimal  @default(21) @db.Decimal(5, 2) // % de IVA (ej: 21.00)
  subtotal    Int      // Subtotal sin impuestos en céntimos
  taxAmount   Int      // Impuestos de esta línea en céntimos
  total       Int      // Total de esta línea en céntimos

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}
